{
  "name": "Invoice",
  "type": "object",
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Invoice number"
    },
    "invoice_type": {
      "type": "string",
      "enum": [
        "standard",
        "proforma",
        "credit_note"
      ],
      "default": "standard",
      "description": "Type of invoice"
    },
    "client_name": {
      "type": "string",
      "description": "Client name"
    },
    "client_email": {
      "type": "string",
      "description": "Client email"
    },
    "client_phone": {
      "type": "string",
      "description": "Client phone (with country code)"
    },
    "items": {
      "type": "array",
      "description": "Invoice line items",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "product",
              "service"
            ],
            "description": "Product or service"
          },
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "description": "e.g. cope, kg, ore, m2"
          },
          "price_ex_vat": {
            "type": "number",
            "description": "Unit price without VAT"
          },
          "vat_rate": {
            "type": "number",
            "description": "VAT % e.g. 20"
          },
          "price_inc_vat": {
            "type": "number",
            "description": "Unit price with VAT"
          },
          "line_total": {
            "type": "number",
            "description": "Qty * price_inc_vat"
          }
        }
      }
    },
    "subtotal": {
      "type": "number",
      "description": "Total without VAT"
    },
    "discount_type": {
      "type": "string",
      "enum": [
        "none",
        "percentage",
        "fixed"
      ],
      "default": "none",
      "description": "Type of discount"
    },
    "discount_value": {
      "type": "number",
      "default": 0,
      "description": "Discount value (% or fixed amount)"
    },
    "discount_amount": {
      "type": "number",
      "default": 0,
      "description": "Calculated discount amount"
    },
    "vat_amount": {
      "type": "number",
      "description": "Total VAT amount"
    },
    "amount": {
      "type": "number",
      "description": "Invoice total with VAT in EUR"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "paid",
        "partially_paid",
        "overdue",
        "cancelled"
      ],
      "default": "draft"
    },
    "is_open": {
      "type": "boolean",
      "description": "Is the invoice open (unpaid)",
      "default": true
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "bank_transfer",
        "card",
        "other"
      ],
      "description": "How the invoice was paid"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string"
    },
    "payment_notes": {
      "type": "string",
      "description": "Payment instructions or notes"
    },
    "issued_by": {
      "type": "string",
      "description": "Email of staff who issued"
    },
    "is_recurring": {
      "type": "boolean",
      "default": false,
      "description": "Is this a recurring invoice"
    },
    "recurring_interval": {
      "type": "string",
      "enum": [
        "monthly",
        "quarterly",
        "yearly"
      ],
      "description": "Recurrence interval if recurring"
    },
    "parent_invoice_id": {
      "type": "string",
      "description": "ID of the invoice this was duplicated from"
    }
  },
  "required": [
    "invoice_number",
    "client_name",
    "amount"
  ]
}