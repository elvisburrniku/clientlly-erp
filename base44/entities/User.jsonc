{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "superadmin",
        "admin",
        "user"
      ],
      "default": "user",
      "description": "User role in the system"
    },
    "tenant_id": {
      "type": "string",
      "description": "ID of the tenant this user belongs to"
    },
    "tenant_name": {
      "type": "string",
      "description": "Name of the tenant for quick access"
    }
  }
}